# Copy this file to .env.local and fill in real values. Do NOT commit .env.local.

# Supabase Postgres connection string. Use the POOLER host (the direct host is
# IPv6-only and fails in many environments). URL-encode special chars in the password.
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres

# Anthropic Claude API key — powers the AI planning copilot.
ANTHROPIC_API_KEY=sk-ant-...

# Geocoding: "mapbox" (recommended, POI-aware) or "nominatim" (no key, less accurate).
GEOCODING_PROVIDER=mapbox
# Mapbox access token (required when GEOCODING_PROVIDER=mapbox).
MAPBOX_TOKEN=pk....

# Routing provider and endpoint (drive times/distances).
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=https://router.project-osrm.org

# MapTiler key for vector map tiles. Optional — falls back to CartoDB raster if unset.
# This is a NEXT_PUBLIC_ key (shipped to the browser by design); protect it with a
# domain allowlist in the MapTiler dashboard rather than secrecy.
NEXT_PUBLIC_MAPTILER_KEY=
